# Backend Environment Variables for Production (Railway)

# Database
MYSQL_URL=mysql://user:password@host:port/database

# Server
PORT=5000
NODE_ENV=production

# Frontend URL for CORS
# https://pnasoft-frontend-production.up.railway.app (ACTUALIZAR CON TU URL DE FRONTEND)
FRONTEND_URL=https://pnasoft-frontend-production.up.railway.app

# JWT Secret (keep secure!)
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
